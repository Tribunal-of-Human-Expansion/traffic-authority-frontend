# For local Vite dev, keep these relative and let Vite proxy to gateway.
VITE_API_BASE_URL=/api
VITE_GATEWAY_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Optional direct overrides (leave empty to use VITE_API_BASE_URL)
VITE_COMPATIBILITY_API_BASE_URL=
VITE_ROUTE_API_BASE_URL=
VITE_AUDIT_API_BASE_URL=
VITE_USER_API_BASE_URL=
VITE_NOTIFICATION_API_BASE_URL=

# If authority is not routed through gateway, set full URL here.
# Example: http://localhost:8083
VITE_AUTHORITY_API_BASE_URL=
